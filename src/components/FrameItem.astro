---
import Button from './Button.astro';

export interface SubmissionData {
  iframeUrl: string;
  repoUrl: string;
  description: string;
  hackatimeProjectNames: string;
  wantsPrize: boolean;
}

export interface Props {
  frameId: number;
  title: string;
  url: string;
  availableTiles: number;
  isPending?: boolean;
  lastSubmission?: SubmissionData | null;
}

const { frameId, title, url, availableTiles, isPending = false, lastSubmission } = Astro.props;
---

<div class="frame-item">
  <div class="frame-header">
    <div class="frame-info">
      <strong>{title}</strong><br />
      <small>
        {isPending && 'Pending approval!'}
        {!isPending && `Available tiles: ${availableTiles}`}
      </small>
    </div>
    {lastSubmission && !isPending && (
      <button
        class="btn-reship"
        data-submission={JSON.stringify({ ...lastSubmission, frameId })}
      >
        Re-ship
      </button>
    )}
  </div>
  {availableTiles > 0 && !isPending && (
    <Button
      class="btn-place-tile"
      data-frame-id={frameId.toString()}
      data-original-text={`Place tile (${availableTiles} available)`}
    >
      Place tile ({availableTiles} available)
    </Button>
  )}
</div>

<style>
  .frame-item {
    border: 2px solid #000;
    padding: 0.8em;
    margin: 0.5em 0;
    background: #fff;

    .frame-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5em;
      margin-bottom: 0.5em;
    }

    .frame-info {
      flex: 1;
      min-width: 0;

      strong {
        color: #000;
        word-break: break-all;
      }

      small {
        color: #000;
      }
    }

    .btn-reship {
      flex-shrink: 0;
      background: #fff;
      border: 2px solid #000;
      font-family: inherit;
      font-size: 1em;
      padding: 0.3em 0.75em;
      cursor: pointer;
      transition: color 0.25s, background 0.25s;

      &:hover {
        background: #000;
        color: #fff;
      }
    }
  }
</style>
