---
import { getCurrentUser } from "../lib/server-auth";
import { isAdmin } from "../lib/admin";
import { getSlackUsername } from "../lib/slack";

const currentUser = await getCurrentUser(Astro);
if (!currentUser || !isAdmin(currentUser)) {
  return Astro.redirect("/");
}

const adminSlackName = await getSlackUsername(currentUser.slackId);

export interface Props {
  title: string;
  activeTab?: string;
}

const { title, activeTab } = Astro.props;

const navItems = [
  { href: "/admin", label: "Dashboard", id: "dashboard" },
  { href: "/admin/submissions", label: "Submissions", id: "submissions" },
  { href: "/admin/tiles", label: "Tiles", id: "tiles" },
  { href: "/admin/users", label: "Users", id: "users" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | iplace Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Privacy-friendly analytics by Plausible -->
    <script async src="https://plausible.io/js/pa-Yo58gcrCbtX52uqHY_qlX.js"></script>
    <script>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>
  </head>

  <style is:global>
    * {
      box-sizing: border-box;
      font-family: "IBM Plex Mono", monospace;
    }
    html, body { margin: 0; padding: 0; background: #f5f5f5; }
  </style>

  <body>
    <div class="admin-shell">
      <nav class="sidebar">
        <div class="sidebar-header">
          <a href="/" class="logo">&lt;iplace&gt;</a>
          <span class="badge">admin</span>
        </div>
        <ul>
          {navItems.map(item => (
            <li>
              <a href={item.href} class:list={{ active: activeTab === item.id }}>{item.label}</a>
            </li>
          ))}
        </ul>
        <div class="sidebar-footer">
          Logged in as {adminSlackName}
        </div>
      </nav>
      <main>
        <h1>{title}</h1>
        <slot />
      </main>
    </div>
  </body>

  <style>
    .admin-shell {
      display: flex;
      min-height: 100vh;
    }
    .sidebar {
      width: 220px;
      background: #000;
      color: #fff;
      padding: 1.5em 1em;
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }
    .sidebar-header {
      display: flex;
      align-items: center;
      gap: 0.5em;
      margin-bottom: 2em;
    }
    .logo {
      color: #fff;
      text-decoration: none;
      font-weight: 700;
      font-size: 1.1em;
    }
    .badge {
      background: #fff;
      color: #000;
      font-size: 0.7em;
      padding: 0.15em 0.4em;
      font-weight: 600;
    }
    .sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
      flex: 1;
    }
    .sidebar li a {
      display: block;
      color: #aaa;
      text-decoration: none;
      padding: 0.5em 0.5em;
      border: 1px solid transparent;
      margin-bottom: 0.25em;
      transition: color 0.2s, border-color 0.2s;
    }
    .sidebar li a:hover {
      color: #fff;
      border-color: #555;
    }
    .sidebar li a.active {
      color: #fff;
      border-color: #fff;
    }
    .sidebar-footer {
      font-size: 0.8em;
      color: #666;
      margin-top: 2em;
    }
    main {
      flex: 1;
      padding: 2em;
      overflow-x: auto;
    }
    main h1 {
      margin-top: 0;
      font-size: 1.5em;
      border-bottom: 2px solid #000;
      padding-bottom: 0.5em;
      margin-bottom: 1em;
    }
  </style>
</html>
