---
import { TILE_SIZE, CANVAS_WIDTH, CANVAS_HEIGHT, SECONDS_PER_TILE } from "../config";
import { getCurrentUser } from "../lib/server-auth";

import prisma from "../lib/prisma";
import type * as db from "../prisma/generated/client";

import Button from "../components/Button.astro";
import NoticeOverlay from "../components/NoticeOverlay.astro";
import FrameItem from "../components/FrameItem.astro";
import Details from "../components/Details.astro";
import Modal from "../components/Modal.astro";

const currentUser = await getCurrentUser(Astro);
const isYswsEligible = currentUser?.verificationStatus === "verified";

function normalizeUrl(raw: string): string {
  try {
    const url = new URL(raw);
    return `${url.protocol}//${url.host}${url.pathname}`.replace(/\/+$/, "");
  } catch {
    return raw.replace(/[?#].*$/, "").replace(/\/+$/, "");
  }
}

interface MergedFrame {
  frameIds: number[];
  url: string;
  availableTiles: number;
  isPending: boolean;
  lastSubmission: {
    iframeUrl: string;
    repoUrl: string;
    description: string;
    hackatimeProjectNames: string;
    wantsPrize: boolean;
  } | null;
}

let mergedFrames: MergedFrame[] = [];
if (currentUser) {
  const rawFrames = await prisma.frame.findMany({
    where: { ownerId: currentUser.id },
    include: { submission: true },
    orderBy: { createdAt: "desc" },
  });

  const byUrl = new Map<string, typeof rawFrames>();
  for (const frame of rawFrames) {
    const key = normalizeUrl(frame.url);
    const group = byUrl.get(key) ?? [];
    group.push(frame);
    byUrl.set(key, group);
  }

  for (const [, frames] of byUrl) {
    const hasPending = frames.some(f => f.isPending);
    const totalAvailable = frames.reduce((sum, f) => {
      if (f.isPending) return sum;
      return sum + Math.max(0, Math.floor((f.approvedTime || 0) / SECONDS_PER_TILE) - f.placedTiles);
    }, 0);

    // Use the most recent submission for re-ship data
    const latestWithSubmission = frames.find(f => f.submission);
    const sub = latestWithSubmission?.submission;

    mergedFrames.push({
      frameIds: frames.map(f => f.id),
      url: frames[0].url,
      availableTiles: totalAvailable,
      isPending: hasPending,
      lastSubmission: sub ? {
        iframeUrl: sub.iframeUrl,
        repoUrl: sub.repoUrl,
        description: sub.description,
        hackatimeProjectNames: sub.hackatimeProjectNames,
        wantsPrize: sub.wantsPrize,
      } : null,
    });
  }
}
